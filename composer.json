{
  "name": "clinic/api-clinical-lab",
  "description": "Hexagonal architecture sample for clinical lab module.",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "ext-pdo": "*",
    "firebase/php-jwt": "^7.0",
    "slim/slim": "^4.12",
    "slim/psr7": "^1.6",
    "dompdf/dompdf": "^2.0",
    "phpmailer/phpmailer": "^6.9"
  },
  "autoload": {
    "psr-4": {
      "ClinicalLab\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  }
}
