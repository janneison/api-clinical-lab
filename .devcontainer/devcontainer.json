{
  "name": "api-clinical-lab",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": "false",
      "enableNonRootDocker": "true",
      "dockerDashComposeVersion": "v2"
    }
  },
  "postCreateCommand": "composer install && pre-commit install",
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        "bmewburn.vscode-intelephense-client",
        "xdebug.php-pack"
      ]
    }
  }
}
